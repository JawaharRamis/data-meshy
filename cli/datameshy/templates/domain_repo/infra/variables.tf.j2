variable "domain" {
  description = "Domain name for this data mesh domain."
  type        = string
}

variable "account_id" {
  description = "AWS account ID for this domain."
  type        = string
}

variable "owner" {
  description = "Owner email address for this domain."
  type        = string
}

variable "aws_region" {
  description = "AWS region to deploy resources in."
  type        = string
  default     = "us-east-1"
}
