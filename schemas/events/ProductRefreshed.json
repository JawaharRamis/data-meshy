{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/data-meshy/schemas/events/ProductRefreshed.json",
  "title": "ProductRefreshed",
  "description": "Event emitted when a data product is successfully refreshed and the central catalog.",
  "type": "object",
  "required": ["event_id", "domain", "timestamp", "version"],
  "properties": {
    "event_id": {
      "description": "Unique event identifier for deduplication (UUID format).",
      "type": "string",
      "format": "uuid"
    },
    "domain": {
      "description": "Domain name this event belongs to.",
      "type": "string"
    },
    "product_name": {
      "description": "Product name.",
      "type": "string"
    },
    "product_id": {
      "description": "Composite key: domain#product_name.",
      "type": "string"
    },
    "schema_version": {
      "description": "Schema version of the product.",
      "type": "integer"
    },
    "quality_score": {
      "description": "Quality score from latest refresh.",
      "type": "number"
    },
    "rows_written": {
      "description": "Number of rows written in latest refresh.",
      "type": "integer"
    },
    "pipeline_execution_arn": {
      "description": "Pipeline execution ARN.",
      "type": "string"
    }
  }
}