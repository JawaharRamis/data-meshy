{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/data-meshy/schemas/events/QualityAlert.json",
  "title": "QualityAlert",
  "description": "Event emitted when a data quality check fails below the quality threshold.",
  "type": "object",
  "required": ["event_id", "domain", "timestamp", "version"],
  "properties": {
    "event_id": {
      "description": "Unique event identifier for deduplication (UUID format).",
      "type": "string",
      "format": "uuid"
    },
    "domain": {
      "description": "Domain name this event belongs to.",
      "type": "string"
    },
    "product_name": {
      "description": "Product name.",
      "type": "string"
    },
    "product_id": {
      "description": "Composite key: domain#product_name.",
      "type": "string"
    },
    "failed_rules": {
      "description": "List of failed quality rules.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quality_score": {
      "description": "Quality score at evaluation.",
      "type": "number"
    },
    "pipeline_execution_arn": {
      "description": "Step Functions execution ARN.",
      "type": "string"
    }
  }
}